#include <iostream>
#include <vector>
#include <fstream>
#include <iomanip>
#include <string>
#include <algorithm>

using namespace std;

// --- Product Class ---
class Product {
public:
    int id;
    string name;
    double price;
    int quantity;

    Product(int i, string n, double p, int q) : id(i), name(n), price(p), quantity(q) {}

    void display() const {
        cout << left << setw(10) << id << setw(20) << name << setw(10) << price << setw(10) << quantity << endl;
    }

    // Convert object to string for file storage
    string toFileData() const {
        return to_string(id) + "," + name + "," + to_string(price) + "," + to_string(quantity);
    }
};

// --- Inventory Manager Class ---
class InventoryManager {
private:
    vector<Product> products;
    const string fileName = "inventory.txt";

public:
    InventoryManager() { loadFromFile(); }

    void addProduct() {
        int id, qty;
        string name;
        double price;

        cout << "Enter ID, Name, Price, Quantity: ";
        cin >> id >> name >> price >> qty;
        
        products.emplace_back(id, name, price, qty);
        saveToFile();
        cout << "Product added successfully!\n";
    }

    void viewInventory() {
        cout << "\n--- Current Inventory ---\n";
        cout << left << setw(10) << "ID" << setw(20) << "Name" << setw(10) << "Price" << setw(10) << "Qty" << endl;
        for (const auto& p : products) p.display();
        checkLowStock();
    }

    void calculateTotalValue() {
        double total = 0;
        for (const auto& p : products) total += (p.price * p.quantity);
        cout << "\nTotal Inventory Value: $" << fixed << setprecision(2) << total << endl;
    }

    void checkLowStock() {
        cout << "\n[Alerts]: ";
        bool clean = true;
        for (const auto& p : products) {
            if (p.quantity < 5) { // Threshold
                cout << p.name << " is LOW (" << p.quantity << ") | ";
                clean = false;
            }
        }
        if (clean) cout << "All stock levels healthy.";
        cout << endl;
    }

    // --- File Handling ---
    void saveToFile() {
        ofstream outFile(fileName);
        for (const auto& p : products) outFile << p.toFileData() << endl;
        outFile.close();
    }

    void loadFromFile() {
        ifstream inFile(fileName);
        if (!inFile) return;
        string line, name;
        int id, qty;
        double price;
        // Simple comma-separated parsing logic would go here
        inFile.close();
    }
};

int main() {
    InventoryManager im;
    int choice;

    do {
        cout << "\n1. Add 2. View 3. Value 4. Exit\nChoice: ";
        cin >> choice;
        switch(choice) {
            case 1: im.addProduct(); break;
            case 2: im.viewInventory(); break;
            case 3: im.calculateTotalValue(); break;
        }
    } while (choice != 4);

    return 0;
}
